- name: Grant appadmintemp passwordless sudo to solace user (only if not already configured)
  hosts: "{{ override_host | default( applicable_host | default('ha_servers') ) }}"
  become: true
  become_method: sudo
  become_user: root
  gather_facts: false
  vars:
    sudoers_file: /etc/sudoers.d/appadmintemp-solace
    admin_user: appadmintemp
  tasks:
    - name: Check if sudoers file already exists for {{ admin_user }}
      stat:
        path: "{{ sudoers_file }}"
      register: sudoers_stat

    - name: Check if correct rule is already present in existing file
      command: grep -qF "{{ admin_user }} ALL=({{ solace_local_service_user }}) NOPASSWD" {{ sudoers_file }}
      register: sudoers_check
      failed_when: false
      changed_when: false
      when: sudoers_stat.stat.exists

    - name: Create sudoers entry for {{ admin_user }} -> {{ solace_local_service_user }} (passwordless)
      copy:
        dest: "{{ sudoers_file }}"
        content: |
          # Allow {{ admin_user }} to become {{ solace_local_service_user }} without password
          # Created by Ansible - site-ha-targeted-grant-sudo-appadmintemp.yml
          {{ admin_user }} ALL=({{ solace_local_service_user }}) NOPASSWD: ALL
        owner: root
        group: root
        mode: '0440'
      when: >
        not sudoers_stat.stat.exists or
        (sudoers_stat.stat.exists and sudoers_check.rc != 0)
      register: sudoers_created

    - name: Validate sudoers file syntax
      command: visudo -cf {{ sudoers_file }}
      changed_when: false

    - name: Show current sudoers entry
      command: cat {{ sudoers_file }}
      register: sudoers_content
      changed_when: false

    - name: Display result
      debug:
        msg: "{{ sudoers_content.stdout_lines }}"
