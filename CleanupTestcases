# however you get into solace on VM2 — direct login, or root->su per the existing model
export XDG_RUNTIME_DIR=/run/user/5011
export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/5011/bus

echo "=== B1. user systemd manager reachable (must say running/degraded) ==="
systemctl --user is-system-running

echo "=== B2. podman works rootless + storage driver/root ==="
podman info --format 'driver={{.Store.GraphDriverName}} graphroot={{.Store.GraphRoot}} runroot={{.Store.RunRoot}}'

echo "=== B3. podman-compose present + path (unit references this path) ==="
which podman-compose || ls -l ~/.local/bin/podman-compose

echo "=== B4. subuid mapping actually works (no setresuid error) ==="
podman unshare cat /proc/self/uid_map

echo "=== B5. THE substrate proof: can a container make memory executable? ==="
echo "    (this is what caught the SELinux relabel issue on VM1)"
podman run --rm -u 1000:1000 \
  artifactory.global.example.com/gv-images-products/oss/solace-pubsub-enterprise:10.25.0.217 \
  /bin/echo "exec-ok" 2>&1 | tail -3

echo "=== B6. image present / pullable ==="
podman images | grep solace-pubsub || echo "image not pulled yet (podman pull needed)"

echo "=== B7. free space on graphroot (need >3-4GB for image) ==="
df -h /app/solace/podman/graphroot
