# A. the ansible connect/become mechanism (answers Q1)
grep -rn 'ansible_user\|remote_user\|become' inventories/ group_vars/ ansible.cfg 2>/dev/null

# B. do run and compose paths use the SAME container UID? (decides if storage survives a switch)
#    podman-run branch: grep the --user value;  compose branch: the user: line
