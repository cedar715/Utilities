# what the prod user-manager ceiling actually is (your provisioning play must reproduce this)
cat /proc/$(podman inspect -f '{{.State.Pid}}' solace)/limits | grep -iE 'open files|locked memory'

# the prod compose/run setup for reference — how solace.service actually launches it
cat ~/.config/systemd/user/solace.service | grep -iE 'ExecStart|Type|XDG|podman'

# subuid range prod uses
cat /etc/subuid | grep solace 2>/dev/null || echo "can't read (need root) — check on new VM instead"
