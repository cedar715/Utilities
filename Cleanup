# the configured ceiling on the user manager unit (this is where our drop-in lands)
systemctl show user@5011.service -p LimitNOFILE -p LimitMEMLOCK

# and the ground truth — the actual limits the running manager has,
# which everything it spawns (podman -> container) inherits
cat /proc/$(pgrep -u solace -xo systemd)/limits | grep -iE 'open files|locked memory'
