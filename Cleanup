# is the existing broker a USER unit? (it will be)
systemctl --user list-unit-files | grep -i solace
ls -l ~/.config/systemd/user/*solace* 2>/dev/null

# is linger on for solace?
loginctl show-user "$(id -un)" -p Linger

# what's running, under whom (you, solace)
systemctl --user list-units --type=service | grep -i solace
podman ps

# your rootless storage
podman info --format '{{.Store.GraphRoot}}'
