# 1. Is there a SYSTEM (root) unit for solace, or not?
sudo systemctl list-unit-files | grep -i solace
ls -l /etc/systemd/system/*solace* 2>/dev/null || echo "no system unit"

# 2. Is there a USER (rootless) unit instead?
sudo ls -l /home/solace/.config/systemd/user/ 2>/dev/null || echo "no user units dir"
sudo loginctl show-user solace -p Linger 2>/dev/null || echo "no linger / no user manager"

# 3. THE deciding question — what user does the running broker process belong to?
sudo podman ps 2>/dev/null | grep -i solace          # rootful podman lives under root
ps -ef | grep -i '[s]olacedaemon\|[b]oot.sh'         # look at the UID column (root vs solace)

# 4. Who owns the container storage in use?
sudo podman info --format '{{.Store.GraphRoot}} (rootful)' 2>/dev/null
sudo -u solace podman info --format '{{.Store.GraphRoot}} (rootless)' 2>/dev/null || echo "rootless check needs the su/runuser path"
