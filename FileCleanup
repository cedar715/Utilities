# stop the crash loop
systemctl --user stop solace.service

# wipe the stale storage (podman unshare so ownership/namespace is right)
podman unshare rm -rf /home/solace/solace/storage-group
mkdir -p /home/solace/solace/storage-group
# re-apply container-UID ownership (the step the playbook's unshare role does)
podman unshare chown -R 1000:1000 /home/solace/solace/storage-group

# start fresh — broker initializes clean storage for THIS image version
systemctl --user start solace.service

# watch it get past the audit this time
sleep 30
podman logs solace 2>&1 | tail -30
