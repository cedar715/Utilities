# as solace on VM2 — stop the loop
systemctl --user stop solace.service

# create the path GHCP's compose currently points at, OR switch the compose to VM1's path.
# Cleaner: switch compose to VM1's model. Edit ~/solace/solace/solace-compose.yml:
#   user: "1000:1000"
#   volumes:
#     - ./storage-group:/var/lib/solace:Z
#   (delete the named-volume block at the bottom)

mkdir -p /home/solace/solace/storage-group
podman unshare chown -R 1000:1000 /home/solace/solace/storage-group

systemctl --user start solace.service
sleep 30
podman logs solace 2>&1 | tail -30      # vmr-solaudit traceback should be GONE
