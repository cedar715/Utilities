# 1. the LAST death's reason + timing (is systemd killing it, or is it self-exiting?)
systemctl --user status solace.service --no-pager | tail -15

# 2. the broker's final words THIS boot — is vmr-solaudit still there, or something new?
podman logs solace 2>&1 | tail -40

# 3. is the storage now present + correctly owned? (did the fix actually hold?)
podman unshare ls -lan /home/solace/solace/storage-group 2>/dev/null || echo "STILL MISSING at ~/solace"
ls -la /opt/apps/solace/storage-group 2>/dev/null || echo "not at /opt/apps either"

# 4. what does the compose ACTUALLY say right now (did your edit save?)
grep -iE 'user:|volumes:|/var/lib/solace|device:|storage' /home/solace/solace/solace-compose.yml
