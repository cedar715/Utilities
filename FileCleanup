## The two files (verbatim, working)

### `solace-compose.yml`
```yaml
services:
  solace:
    image: artifactory.global.<corp>.com/gv-images-products/oss/solace-pubsub-enterprise:10.25.0.217
    container_name: solace
    hostname: solace1                 # unique per node (solace1/solace2/solace3)
    user: "1000:1000"                 # REQUIRED: image default UID is 1000001, too large for the subuid range
    shm_size: 1g
    ulimits:
      core: -1
      nofile:
        soft: 2448
        hard: 1048576                 # Solace POST requires exactly this; must be <= user-manager ceiling
      # NOTE: no `memlock` line on purpose — inherited from user@.service (LimitMEMLOCK=infinity).
      # Putting memlock here breaks `podman exec` (setrlimit not permitted in the exec shell).
    ports:
      - "8080:8080"      # SEMP / mgmt
      - "1943:1943"      # SEMP TLS
      - "55555:55555"    # SMF
      - "55003:55003"    # SMF compressed
      - "55443:55443"    # SMF TLS
      - "8008:8008"      # web messaging
      - "2222:2222"      # SSH CLI
    volumes:
      - ./storage-group:/var/lib/solace:Z
    environment:
      username_admin_globalaccesslevel: admin
      username_admin_password: admin            # change + vault for anything beyond DEV
      system_scaling_maxconnectioncount: "100"
```

### `solace.service` (at `~/.config/systemd/user/solace.service`)
```ini
[Unit]
Description=Solace PubSub+ broker (rootless podman-compose)
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/solace
ExecStartPre=-%h/.local/bin/podman-compose -f %h/solace/solace-compose.yml down
ExecStart=%h/.local/bin/podman-compose -f %h/solace/solace-compose.yml up
ExecStop=%h/.local/bin/podman-compose -f %h/solace/solace-compose.yml down
Restart=on-failure
RestartSec=10
TimeoutStartSec=600
TimeoutStopSec=120

[Install]
WantedBy=default.target
```

