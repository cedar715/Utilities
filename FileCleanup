# 1. WHY systemd thinks it must restart — exit code, signal, timing
systemctl --user status solace.service --no-pager -l | tail -30

# 2. the broker's OWN last words before each death (the real cause)
podman logs solace 2>&1 | tail -60

# 3. is it the broker dying, or systemd killing a healthy broker? (the timing tell)
journalctl --user -u solace.service --no-pager --since "15 min ago" \
  | grep -iE 'stopp|kill|timeout|start-limit|watchdog|oom|notify|sigterm|sigkill|main pid' | tail -40
