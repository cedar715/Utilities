# from appadmintemp — the sudoers grant makes this work now
sudo -u solace bash
# you're now solace; set the session vars (needed for podman)
export XDG_RUNTIME_DIR=/run/user/5011
export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/5011/bus

# on VM2 — what's actually in the storage-group the broker is auditing?
podman unshare ls -lan /home/solace/solace/storage-group
podman unshare ls -lan /home/solace/solace/storage-group/var 2>/dev/null
podman unshare find /home/solace/solace/storage-group -maxdepth 2 -name '*soltr*' 2>/dev/null

# on VM1 (the stable one) — same listing, to diff against
podman unshare ls -lan /home/solace/solace/storage-group
