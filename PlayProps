#!/usr/bin/env bash
# clean-slate.sh
# Run on EACH of the 3 VMs, as the `solace` user, inside a REAL session:
#   sudo machinectl shell solace@.host    (NOT runuser / su -)
# Safe: pre-prod, no real data. Wipes broker data + rootless podman state.
# Does NOT touch host substrate (cgroup v2, linger, rlimits) — those stay.
set -uo pipefail

echo "== 1. stop + disable the broker user unit (if present) =="
systemctl --user stop    solace.service 2>/dev/null || true
systemctl --user disable solace.service 2>/dev/null || true

echo "== 2. tear down the compose stack =="
( cd "$HOME/solace" 2>/dev/null && \
  "$HOME/.local/bin/podman-compose" -f solace-compose.yml down ) 2>/dev/null || true

echo "== 3. reset rootless podman for this user (containers/pods/networks/volumes/images) =="
podman pod rm -af  2>/dev/null || true
podman rm -af      2>/dev/null || true
podman system reset --force            # nuclear, clean. you will re-pull the image after.

echo "== 4. WIPE storage-group (REQUIRED: config keys only apply vs EMPTY storage) =="
rm -rf "$HOME/solace/storage-group"
mkdir -p "$HOME/solace/storage-group"

echo "== 5. check for STRAY ROOTFUL containers from earlier tests =="
echo "   (if anything lists below, clean it with the two sudo lines beneath)"
sudo podman ps -a 2>/dev/null || true
# sudo podman rm -af
# sudo podman system reset --force

echo
echo "== DONE on $(hostname). Re-pull image, then verify substrate before bring-up. =="
