# solace.service  — ROOTLESS systemd USER unit (NOT a system unit).
# Place at: /home/solace/.config/systemd/user/solace.service
# This is what gives you "podman-compose under systemd" without rootful.
#
# Confirm your podman-compose path first:  which podman-compose
# (your env had it at ~/.local/bin/podman-compose)

[Unit]
Description=Solace PubSub+ broker (rootless podman-compose)
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/solace
# 'down' first cleans stale state ('-' ignores failure on first boot)
ExecStartPre=-%h/.local/bin/podman-compose -f %h/solace/solace-compose.yml down
# Foreground 'up' so systemd has something to supervise — never 'up -d'
ExecStart=%h/.local/bin/podman-compose -f %h/solace/solace-compose.yml up
ExecStop=%h/.local/bin/podman-compose -f %h/solace/solace-compose.yml down
Restart=on-failure
RestartSec=10
TimeoutStartSec=600
TimeoutStopSec=120

[Install]
WantedBy=default.target
